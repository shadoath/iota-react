---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-blue to-brand-purple flex items-center justify-center text-white font-bold text-sm">
          N
        </div>
        <span class="text-lg font-bold text-white">NodusNexus</span>
        <span class="text-gray-600 text-sm ml-2">The card game of matching patterns</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href="https://game.nodusnexus.com" class="hover:text-white transition-colors">Play</a>
        <a href="#how-it-works" class="hover:text-white transition-colors">How It Works</a>
        <a href="#benefits" class="hover:text-white transition-colors">Benefits</a>
        <a href="#modes" class="hover:text-white transition-colors">Modes</a>
      </div>

      <!-- Copyright -->
      <p class="text-sm text-gray-600">
        &copy; {currentYear} NodusNexus. Free to play, forever.
      </p>
    </div>
  </div>
</footer>
