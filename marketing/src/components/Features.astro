---

<section id="features" class="py-24 lg:py-32 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-red/10 text-brand-red text-sm font-medium mb-4">
        Packed With Features
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        Everything You Need, Nothing You Don't
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Polished, accessible, and free. Built with care for players who appreciate quality.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((feature, i) => (
        <div class={`reveal reveal-delay-${(i % 4) + 1} group p-5 rounded-xl bg-white/[0.03] border border-white/5 hover:border-white/10 transition-all duration-300 hover:bg-white/[0.05]`}>
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-gray-400 group-hover:text-white mb-3 transition-colors">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-sm font-bold text-white mb-1">{feature.title}</h3>
          <p class="text-gray-500 text-xs leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
