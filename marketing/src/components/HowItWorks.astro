---
const steps = [
  {
    number: '01',
    title: 'Draw Your Hand',
    description: 'Start with 4 cards, each with a unique combination of color, shape, and number. 64 unique cards plus 2 wilds make every game different.',
    color: 'brand-blue',
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="6" width="12" height="18" rx="2" /><rect x="16" y="4" width="12" height="18" rx="2" opacity="0.5" /><rect x="10" y="8" width="12" height="18" rx="2" opacity="0.7" /></svg>`,
  },
  {
    number: '02',
    title: 'Match Patterns',
    description: 'Place cards on the board so every line follows one rule: each attribute (color, shape, number) must be either all the same or all different.',
    color: 'brand-green',
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="4" /><rect x="18" y="6" width="8" height="8" /><polygon points="14,22 18,30 10,30" /><line x1="22" y1="22" x2="22" y2="30" stroke-linecap="round" /><line x1="18" y1="26" x2="26" y2="26" stroke-linecap="round" /></svg>`,
  },
  {
    number: '03',
    title: 'Score & Strategize',
    description: 'Every card in your lines adds to your score. Plan multi-card combos, extend existing lines, and aim for the highest-scoring plays.',
    color: 'brand-yellow',
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 4l3.09 6.26L26 11.27l-5 4.87 1.18 6.88L16 19.77l-6.18 3.25L11 16.14l-5-4.87 6.91-1.01z" /></svg>`,
  },
  {
    number: '04',
    title: 'Win the Game',
    description: 'When the deck runs out and no more moves remain, the player with the highest score wins. Challenge harder AI or invite friends to compete.',
    color: 'brand-purple',
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 8h20M8 8v4c0 4.418 3.582 8 8 8s8-3.582 8-8V8M4 8h4M24 8h4M12 24h8M16 20v4M10 28h12" /></svg>`,
  },
];
---

<section id="how-it-works" class="py-24 lg:py-32 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-blue/10 text-brand-blue text-sm font-medium mb-4">
        Simple to Learn
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        Four Steps to Mastery
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        The rules take a minute to learn. The strategy takes a lifetime to master.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, i) => (
        <div class={`reveal reveal-delay-${i + 1} group relative p-6 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-${step.color}/30 transition-all duration-300 hover:bg-white/[0.05]`}>
          <!-- Step number -->
          <div class={`text-6xl font-black text-${step.color}/10 absolute top-4 right-4 select-none`}>
            {step.number}
          </div>

          <!-- Icon -->
          <div class={`w-14 h-14 rounded-xl bg-${step.color}/10 flex items-center justify-center text-${step.color} mb-5`}>
            <Fragment set:html={step.icon} />
          </div>

          <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
          <p class="text-gray-400 leading-relaxed text-sm">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Visual: Pattern example -->
    <div class="mt-20 reveal">
      <div class="relative max-w-2xl mx-auto">
        <div class="text-center mb-8">
          <h3 class="text-xl font-bold text-white mb-2">The Pattern Rule in Action</h3>
          <p class="text-gray-400 text-sm">Each line must have attributes all the same OR all different</p>
        </div>

        <!-- Example row: All different colors, all circles, all same number -->
        <div class="flex items-center justify-center gap-4 flex-wrap">
          <!-- Red Circle 2 -->
          <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800">
            <div class="absolute top-1 left-2 text-brand-red text-xs font-bold">2</div>
            <svg class="w-8 h-8" viewBox="0 0 32 32">
              <circle cx="16" cy="16" r="10" fill="none" stroke="#ef4444" stroke-width="2.5" />
            </svg>
          </div>

          <!-- Green Circle 2 -->
          <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800">
            <div class="absolute top-1 left-2 text-brand-green text-xs font-bold">2</div>
            <svg class="w-8 h-8" viewBox="0 0 32 32">
              <circle cx="16" cy="16" r="10" fill="none" stroke="#22c55e" stroke-width="2.5" />
            </svg>
          </div>

          <!-- Blue Circle 2 -->
          <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800">
            <div class="absolute top-1 left-2 text-brand-blue text-xs font-bold">2</div>
            <svg class="w-8 h-8" viewBox="0 0 32 32">
              <circle cx="16" cy="16" r="10" fill="none" stroke="#3b82f6" stroke-width="2.5" />
            </svg>
          </div>

          <!-- Yellow Circle 2 -->
          <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800">
            <div class="absolute top-1 left-2 text-brand-yellow text-xs font-bold">2</div>
            <svg class="w-8 h-8" viewBox="0 0 32 32">
              <circle cx="16" cy="16" r="10" fill="none" stroke="#eab308" stroke-width="2.5" />
            </svg>
          </div>
        </div>

        <!-- Labels -->
        <div class="flex justify-center gap-6 mt-6 text-sm">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-brand-green/20 border border-brand-green/50"></span>
            <span class="text-gray-400">Colors: <span class="text-white font-medium">all different</span></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-brand-blue/20 border border-brand-blue/50"></span>
            <span class="text-gray-400">Shapes: <span class="text-white font-medium">all same</span></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-brand-yellow/20 border border-brand-yellow/50"></span>
            <span class="text-gray-400">Numbers: <span class="text-white font-medium">all same</span></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
