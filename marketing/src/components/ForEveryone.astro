---
const audiences = [
  {
    title: 'Kids & Students',
    age: 'Ages 8+',
    description: 'Build logical reasoning and pattern recognition that directly supports math and science learning. The interactive tutorial makes it easy to start, while the Pattern Trainer provides focused drills.',
    highlights: ['Develops logical thinking', 'Supports STEM learning', 'Interactive tutorial', 'Pattern Trainer drills'],
    color: 'brand-green',
    emoji: '🧒',
  },
  {
    title: 'Adults & Professionals',
    age: 'Stay sharp',
    description: 'Exercise strategic planning and decision-making under pressure. Timed mode sharpens quick thinking. Daily Challenges create a healthy habit of mental exercise that fits into any schedule.',
    highlights: ['Strategic depth', 'Quick decision training', 'Daily mental exercise', 'Stress-free focus time'],
    color: 'brand-blue',
    emoji: '🧠',
  },
  {
    title: 'Families & Friends',
    age: 'Play together',
    description: 'A game the whole family can enjoy around one screen or across the internet. Easy enough for beginners with hints on, deep enough to keep veterans engaged. Share room codes and compete.',
    highlights: ['Online multiplayer', 'Adjustable difficulty', 'Practice mode for learners', 'Leaderboard rivalry'],
    color: 'brand-purple',
    emoji: '👨‍👩‍👧‍👦',
  },
];
---

<section class="py-24 lg:py-32 relative">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-purple/[0.02] to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-yellow/10 text-brand-yellow text-sm font-medium mb-4">
        For Everyone
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        A Game That <span class="gradient-text">Grows With You</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        From first-time players to seasoned strategists, NodusNexus meets you where you are.
      </p>
    </div>

    <!-- Audience cards -->
    <div class="grid lg:grid-cols-3 gap-8">
      {audiences.map((audience, i) => (
        <div class={`reveal reveal-delay-${i + 1} group relative`}>
          <div class={`h-full p-8 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-${audience.color}/20 transition-all duration-300`}>
            <!-- Header -->
            <div class="flex items-center gap-4 mb-6">
              <span class="text-4xl">{audience.emoji}</span>
              <div>
                <h3 class="text-xl font-bold text-white">{audience.title}</h3>
                <span class={`text-sm text-${audience.color}`}>{audience.age}</span>
              </div>
            </div>

            <p class="text-gray-400 text-sm leading-relaxed mb-6">{audience.description}</p>

            <!-- Highlights -->
            <ul class="space-y-2">
              {audience.highlights.map((highlight) => (
                <li class="flex items-center gap-2 text-sm">
                  <svg class={`w-4 h-4 text-${audience.color} shrink-0`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-gray-300">{highlight}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
