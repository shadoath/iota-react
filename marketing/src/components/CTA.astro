---
// Final call-to-action section
---

<section class="py-24 lg:py-32 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-gradient-to-r from-brand-blue/10 via-brand-purple/10 to-brand-red/10 rounded-full blur-[128px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="reveal">
      <!-- Decorative cards -->
      <div class="flex justify-center gap-3 mb-8">
        <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800 -rotate-6 hover:rotate-0 transition-transform duration-300">
          <svg class="w-6 h-6" viewBox="0 0 32 32">
            <polygon points="16,4 28,28 4,28" fill="none" stroke="#ef4444" stroke-width="2.5" />
          </svg>
        </div>
        <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800 rotate-2 hover:rotate-0 transition-transform duration-300">
          <svg class="w-6 h-6" viewBox="0 0 32 32">
            <circle cx="16" cy="16" r="10" fill="none" stroke="#3b82f6" stroke-width="2.5" />
          </svg>
        </div>
        <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800 -rotate-3 hover:rotate-0 transition-transform duration-300">
          <svg class="w-6 h-6" viewBox="0 0 32 32">
            <rect x="6" y="6" width="20" height="20" fill="none" stroke="#22c55e" stroke-width="2.5" />
          </svg>
        </div>
        <div class="game-card bg-gradient-to-br from-gray-900 to-gray-800 rotate-6 hover:rotate-0 transition-transform duration-300">
          <svg class="w-6 h-6" viewBox="0 0 32 32">
            <path d="M16 4v24M4 16h24" fill="none" stroke="#eab308" stroke-width="2.5" stroke-linecap="round" />
          </svg>
        </div>
      </div>

      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-6 leading-tight">
        Ready to Train Your<br />
        <span class="gradient-text">Pattern Brain?</span>
      </h2>

      <p class="text-lg text-gray-400 max-w-xl mx-auto mb-8 leading-relaxed">
        No downloads. No sign-ups. No ads. Just a beautifully crafted card game
        that's free, fun, and genuinely good for your mind.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://game.nodusnexus.com"
          class="group px-10 py-4 bg-brand-blue hover:bg-blue-600 text-white font-bold text-lg rounded-full transition-all hover:shadow-xl hover:shadow-blue-500/25 hover:-translate-y-0.5 inline-flex items-center justify-center gap-2"
        >
          Start Playing Now
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <p class="mt-6 text-sm text-gray-600">
        Works on every device. Plays offline. Installs as an app.
      </p>
    </div>
  </div>
</section>
